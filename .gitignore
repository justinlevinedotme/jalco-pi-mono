.DS_Store

# Secrets & auth
pi/.pi/agent/auth.json

# MCP caches (regenerated at runtime)
pi/.pi/agent/mcp-cache.json
pi/.pi/agent/mcp-npx-cache.json

# Sessions (ephemeral, large)
pi/.pi/agent/sessions/

# Binaries (pi recreates these on install)
pi/.pi/agent/bin/
pi/.pi/agent/jars/

# Node modules (reinstall via npm/bun install)
pi/.pi/agent/extensions/node_modules/
pi/.pi/agent/extensions/*/node_modules/
pi/.pi/agent/skills/*/node_modules/

# Build artifacts
pi/.pi/agent/extensions/*/dist/

# MCPorter compiled binaries (regenerate with /mcporter prompt)
pi/.pi/agent/skills/exa/exa

# Personal/private skills (contain PII, voice samples, or account-specific data)
pi/.pi/agent/skills/write-like-justin/
pi/.pi/agent/skills/job-search/
pi/.pi/agent/skills/real-app/

# Personal prompts (contain resume details, contact info)
pi/.pi/agent/prompts/jobs.md

# Update cache (runtime state)
pi/.pi/agent/update-cache.json

# Local pi folder (root level only, not tracked stow files)
/.pi/